index 0000000..c75076f
--- /dev/null
+++ b/src/solar/models/battery_logic.py
@@ -0,0 +1,34 @@
+import numpy as np
+from solar.config import BatteryConfig
+
+def allocate_battery_capacity(config: BatteryConfig) -> dict:
+    """
+    Splits battery capacity and power between FCR and Arbitrage buckets.
+    Ensures fail-fast validation of allocation bounds.
+    
+    Args:
+        config: BatteryConfig object containing physical and market parameters.
+        
+    Returns:
+        dict: Containing 'p_fcr', 'p_arb', and 'e_arb' parameters for the simulation loop.
+        
+    Raises:
+        ValueError: If fcr_allocation_pct is outside the [0, 1] range.
+    """
+    fcr_pct = config.fcr_allocation_pct
+    
+    if not (0.0 <= fcr_pct <= 1.0):
+        raise ValueError(
+            f"fcr_allocation_pct must be strictly bounded between 0.0 and 1.0; got {fcr_pct}"
+        )
+    
+    # Calculate splits according to PRD 5.4
+    p_fcr = config.max_power_kw * fcr_pct
+    p_arb = config.max_power_kw - p_fcr
+    e_arb = config.capacity_kwh * (1.0 - fcr_pct)
+    
+    return {
+        "p_fcr": p_fcr,
+        "p_arb": p_arb,
+        "e_arb": e_arb
+    }
